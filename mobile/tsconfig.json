{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "*"
      ]
    }
  },
  "include": [
    "app",
    "components",
    "constants",
    "hooks",
    "navigation",
    "screens",
    "services",
    "store",
    "theme",
    "types",
    "utils"
  ]
}
